# 로컬 개발용 (infra/docker-compose.yml 기준). 실제 배포 환경 값은 별도 시크릿 매니저 사용.
APP_NAME=시소

DATABASE_URL=jdbc:postgresql://localhost:5432/siso
DATABASE_USER=siso
DATABASE_PASSWORD=siso_dev_only

# 크롤러(psycopg)는 JDBC가 아닌 libpq DSN 형식 사용
CRAWLER_DATABASE_URL=postgresql://siso:siso_dev_only@localhost:5432/siso

REDIS_URL=redis://localhost:6379

# frontend가 SSR 시 피드 API를 호출할 백엔드 주소 (서버 전용, 브라우저에 노출 안 됨)
BACKEND_API_URL=http://localhost:8080

# 관리자 CMS(/admin) 인증 — 백엔드(Basic Auth)와 프론트(proxy.ts 게이트 +
# 백엔드 호출용 헤더) 양쪽 프로세스 환경에 동일한 값으로 설정해야 함
ADMIN_USERNAME=admin
ADMIN_PASSWORD=local-dev-only-password
